{
  "name": "memovyn",
  "version": "0.2.0",
  "description": "Local-first permanent memory for MCP-native coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byte271/memovyn.git"
  },
  "homepage": "https://github.com/byte271/memovyn",
  "bugs": {
    "url": "https://github.com/byte271/memovyn/issues"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "memovyn": "./dist/cli.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "static",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node --experimental-strip-types src/cli.ts",
    "start": "node dist/cli.mjs serve --bind 127.0.0.1:7761",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --outDir dist",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "package:sea": "node scripts/build-sea.mjs",
    "verify:sea": "node scripts/build-sea.mjs",
    "release:check": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.2.4",
    "typescript": "^5.8.3"
  }
}
