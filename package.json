{
  "name": "memovyn",
  "version": "0.2.0",
  "description": "Local-first permanent memory for MCP-native coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byte271/memovyn.git"
  },
  "homepage": "https://github.com/byte271/memovyn",
  "bugs": {
    "url": "https://github.com/byte271/memovyn/issues"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "memovyn": "./dist/cli.mjs"
  },
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "files": [
    "dist",
    "static",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.mjs serve --bind 127.0.0.1:7761",
    "typecheck": "tsc --noEmit",
    "build": "tsup --config tsup.config.ts",
    "test": "tsx --test tests/*.test.ts",
    "package:bundle": "node scripts/build-release-bundle.mjs",
    "package:sea": "node -e \"console.log('SEA packaging is disabled on Node 20. Use npm run package:bundle instead.')\"",
    "release:check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "11.8.1"
  },
  "devDependencies": {
    "@types/node": "20.17.50",
    "tsx": "^4.19.2",
    "tsup": "^8.2.4",
    "typescript": "^5.8.3"
  }
}
